let x = [];
x.insert(0, "foo");
dumpln(x);

let x = [123, 456, 789];
x.insert(1, "foo");
dumpln(x);

let x = [];
try { x.insert(42, "foo"); } catch err { dumpln(err); }
################################################################################
# ["foo"]
# [123, "foo", 456, 789]
# "attempted insert into vector of length 0 with index 42"
