################################################################################
# (0).format("f") is "0"
# (+123).format("f") is "123"
# (-123).format("f") is "-123"
# (+3.14).format("f") is "3.14"
# (-3.14).format("f") is "-3.14"
# (+Inf).format("f") is "Inf"
# (-Inf).format("f") is "-Inf"
# (NaN).format("f") is "NaN"
#
# (0).format("+f") is "+0"
# (+123).format("+f") is "+123"
# (-123).format("+f") is "-123"
# (+3.14).format("+f") is "+3.14"
# (-3.14).format("+f") is "-3.14"
# (+Inf).format("+f") is "+Inf"
# (-Inf).format("+f") is "-Inf"
# (NaN).format("+f") is "NaN"
#
# (0).format("+8f") is "      +0"
# (+123).format("+8f") is "    +123"
# (-123).format("+8f") is "    -123"
# (+3.14).format("+8f") is "   +3.14"
# (-3.14).format("+8f") is "   -3.14"
# (+Inf).format("+8f") is "    +Inf"
# (-Inf).format("+8f") is "    -Inf"
# (NaN).format("+8f") is "     NaN"
#
# (0).format("+08f") is "+0000000"
# (+123).format("+08f") is "+0000123"
# (-123).format("+08f") is "-0000123"
# (+3.14).format("+08f") is "+0003.14"
# (-3.14).format("+08f") is "-0003.14"
# (+Inf).format("+08f") is "    +Inf"
# (-Inf).format("+08f") is "    -Inf"
# (NaN).format("+08f") is "     NaN"
#
# (0).format("+08.3f") is "+000.000"
# (+123).format("+08.3f") is "+123.000"
# (-123).format("+08.3f") is "-123.000"
# (+3.14).format("+08.3f") is "+003.140"
# (-3.14).format("+08.3f") is "-003.140"
# (+Inf).format("+08.3f") is "    +Inf"
# (-Inf).format("+08.3f") is "    -Inf"
# (NaN).format("+08.3f") is "     NaN"
#
# (0).format("#f") produced the error "# flag not supported for decimal float format, received \"#f\""
#
# (0).format("d") is "0"
# (+123).format("d") is "123"
# (-123).format("d") is "-123"
#
# (0).format("+d") is "+0"
# (+123).format("+d") is "+123"
# (-123).format("+d") is "-123"
#
# (0).format("+8d") is "      +0"
# (+123).format("+8d") is "    +123"
# (-123).format("+8d") is "    -123"
#
# (0).format("+08d") is "+0000000"
# (+123).format("+08d") is "+0000123"
# (-123).format("+08d") is "-0000123"
#
# (0).format("#d") produced the error "# flag not supported for decimal integer format, received \"#d\""
# (0).format(".3d") produced the error "precision specifier not supported for decimal integer format, received \".3d\""
# (+3.14).format("d") produced the error "cannot convert 3.14 into an integer without truncation"
# (-3.14).format("d") produced the error "cannot convert -3.14 into an integer without truncation"
# (+Inf).format("d") produced the error "cannot convert Inf into an integer"
# (-Inf).format("d") produced the error "cannot convert -Inf into an integer"
# (NaN).format("d") produced the error "cannot convert NaN into an integer"
#
# (0).format("b") is "0"
# (+123).format("b") is "1111011"
# (-123).format("b") is "-1111011"
#
# (0).format("+b") is "+0"
# (+123).format("+b") is "+1111011"
# (-123).format("+b") is "-1111011"
#
# (0).format("+8b") is "      +0"
# (+123).format("+8b") is "+1111011"
# (-123).format("+8b") is "-1111011"
#
# (0).format("+08b") is "+0000000"
# (+123).format("+08b") is "+1111011"
# (-123).format("+08b") is "-1111011"
#
# (0).format("+#08b") is "+0b00000"
# (0).format("+#016b") is "+0b0000000000000"
# (+123).format("+#08b") is "+0b1111011"
# (-123).format("+#08b") is "-0b1111011"
# (+0xFF).format("#08b") is "0b11111111"
# (-0xFF).format("#08b") is "-0b11111111"
#
# (0).format(".3b") produced the error "precision specifier not supported for binary integer format, received \".3b\""
# (+3.14).format("b") produced the error "cannot convert 3.14 into an integer without truncation"
# (-3.14).format("b") produced the error "cannot convert -3.14 into an integer without truncation"
# (+Inf).format("b") produced the error "cannot convert Inf into an integer"
# (-Inf).format("b") produced the error "cannot convert -Inf into an integer"
# (NaN).format("b") produced the error "cannot convert NaN into an integer"
#
# (0).format("x") is "0"
# (+123).format("x") is "7b"
# (-123).format("x") is "-7b"
#
# (0).format("+x") is "+0"
# (+123).format("+x") is "+7b"
# (-123).format("+x") is "-7b"
#
# (0).format("+8x") is "      +0"
# (+123).format("+8x") is "     +7b"
# (-123).format("+8x") is "     -7b"
#
# (0).format("+08x") is "+0000000"
# (+123).format("+08x") is "+000007b"
# (-123).format("+08x") is "-000007b"
#
# (0).format("+#08x") is "+0x00000"
# (0).format("+#016x") is "+0x0000000000000"
# (+123).format("+#08x") is "+0x0007b"
# (-123).format("+#08x") is "-0x0007b"
# (+0xFF).format("#08x") is "0x0000ff"
# (-0xFF).format("#08x") is "-0x000ff"
#
# (0).format(".3x") produced the error "precision specifier not supported for hexadecimal integer format, received \".3x\""
# (+3.14).format("x") produced the error "cannot convert 3.14 into an integer without truncation"
# (-3.14).format("x") produced the error "cannot convert -3.14 into an integer without truncation"
# (+Inf).format("x") produced the error "cannot convert Inf into an integer"
# (-Inf).format("x") produced the error "cannot convert -Inf into an integer"
# (NaN).format("x") produced the error "cannot convert NaN into an integer"
#
# (0).format("X") is "0"
# (+123).format("X") is "7B"
# (-123).format("X") is "-7B"
#
# (0).format("+X") is "+0"
# (+123).format("+X") is "+7B"
# (-123).format("+X") is "-7B"
#
# (0).format("+8X") is "      +0"
# (+123).format("+8X") is "     +7B"
# (-123).format("+8X") is "     -7B"
#
# (0).format("+08X") is "+0000000"
# (+123).format("+08X") is "+000007B"
# (-123).format("+08X") is "-000007B"
#
# (0).format("+#08X") is "+0X00000"
# (0).format("+#016X") is "+0X0000000000000"
# (+123).format("+#08X") is "+0X0007B"
# (-123).format("+#08X") is "-0X0007B"
# (+0xFF).format("#08X") is "0X0000FF"
# (-0xFF).format("#08X") is "-0X000FF"
#
# (0).format(".3X") produced the error "precision specifier not supported for hexadecimal integer format, received \".3X\""
# (+3.14).format("X") produced the error "cannot convert 3.14 into an integer without truncation"
# (-3.14).format("X") produced the error "cannot convert -3.14 into an integer without truncation"
# (+Inf).format("X") produced the error "cannot convert Inf into an integer"
# (-Inf).format("X") produced the error "cannot convert -Inf into an integer"
# (NaN).format("X") produced the error "cannot convert NaN into an integer"
#
# (0).format("") produced the error "expected format string matching \\+?#?0?\\d*(\\.\\d+)?[fdbxX], received \"\""
# (0).format("oops") produced the error "expected format string matching \\+?#?0?\\d*(\\.\\d+)?[fdbxX], received \"oops\""
# (0).format("+#08") produced the error "expected format string matching \\+?#?0?\\d*(\\.\\d+)?[fdbxX], received \"+#08\""
