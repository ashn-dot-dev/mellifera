# f formatting
println($`(0).format("f") is {repr((0).format("f"))}`);
println($`(+123).format("f") is {repr((+123).format("f"))}`);
println($`(-123).format("f") is {repr((-123).format("f"))}`);
println($`(+3.14).format("f") is {repr((+3.14).format("f"))}`);
println($`(-3.14).format("f") is {repr((-3.14).format("f"))}`);
println($`(+Inf).format("f") is {repr((+Inf).format("f"))}`);
println($`(-Inf).format("f") is {repr((-Inf).format("f"))}`);
println($`(NaN).format("f") is {repr((NaN).format("f"))}`);

print("\n");

println($`(0).format("+f") is {repr((0).format("+f"))}`);
println($`(+123).format("+f") is {repr((+123).format("+f"))}`);
println($`(-123).format("+f") is {repr((-123).format("+f"))}`);
println($`(+3.14).format("+f") is {repr((+3.14).format("+f"))}`);
println($`(-3.14).format("+f") is {repr((-3.14).format("+f"))}`);
println($`(+Inf).format("+f") is {repr((+Inf).format("+f"))}`);
println($`(-Inf).format("+f") is {repr((-Inf).format("+f"))}`);
println($`(NaN).format("+f") is {repr((NaN).format("+f"))}`);

print("\n");

println($`(0).format("+8f") is {repr((0).format("+8f"))}`);
println($`(+123).format("+8f") is {repr((+123).format("+8f"))}`);
println($`(-123).format("+8f") is {repr((-123).format("+8f"))}`);
println($`(+3.14).format("+8f") is {repr((+3.14).format("+8f"))}`);
println($`(-3.14).format("+8f") is {repr((-3.14).format("+8f"))}`);
println($`(+Inf).format("+8f") is {repr((+Inf).format("+8f"))}`);
println($`(-Inf).format("+8f") is {repr((-Inf).format("+8f"))}`);
println($`(NaN).format("+8f") is {repr((NaN).format("+8f"))}`);

print("\n");

println($`(0).format("+08f") is {repr((0).format("+08f"))}`);
println($`(+123).format("+08f") is {repr((+123).format("+08f"))}`);
println($`(-123).format("+08f") is {repr((-123).format("+08f"))}`);
println($`(+3.14).format("+08f") is {repr((+3.14).format("+08f"))}`);
println($`(-3.14).format("+08f") is {repr((-3.14).format("+08f"))}`);
println($`(+Inf).format("+08f") is {repr((+Inf).format("+08f"))}`);
println($`(-Inf).format("+08f") is {repr((-Inf).format("+08f"))}`);
println($`(NaN).format("+08f") is {repr((NaN).format("+08f"))}`);

print("\n");

println($`(0).format("+08.3f") is {repr((0).format("+08.3f"))}`);
println($`(+123).format("+08.3f") is {repr((+123).format("+08.3f"))}`);
println($`(-123).format("+08.3f") is {repr((-123).format("+08.3f"))}`);
println($`(+3.14).format("+08.3f") is {repr((+3.14).format("+08.3f"))}`);
println($`(-3.14).format("+08.3f") is {repr((-3.14).format("+08.3f"))}`);
println($`(+Inf).format("+08.3f") is {repr((+Inf).format("+08.3f"))}`);
println($`(-Inf).format("+08.3f") is {repr((-Inf).format("+08.3f"))}`);
println($`(NaN).format("+08.3f") is {repr((NaN).format("+08.3f"))}`);

print("\n");

try { (0).format("#f"); error "unreachable"; } catch err { println($`(0).format("#f") produced the error {repr(err)}`); }

print("\n");

