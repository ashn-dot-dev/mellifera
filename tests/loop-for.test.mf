for x in 3 {
    println($`x is {x}`);
}

print("\n");

try {
    for x in -3 { }
} catch err {
    dumpln(err);
}

try {
    for x in math::pow(2, 32) { }
} catch err {
    dumpln(err);
}

try {
    for x.& in 3 { }
} catch err {
    dumpln(err);
}

try {
    for k, v in 3 { }
} catch err {
    dumpln(err);
}

print("\n");

let v = ["a", "b", "c"];
for x in v {
    println($`x is {repr(x)}`);
}

print("\n");

let v = [{"foo"}, {"bar"}, {"baz"}];
let i = 1;
dumpln(v);
for x.& in v {
    x.*.insert(i);
    i = i + 1;
}
dumpln(v);

print("\n");

try {
    for k, v in v { }
} catch err {
    dumpln(err);
}

print("\n");

let m = Map{"a": 123, "b": 456, "c": 789};
for k, v in m {
    println($`k is {repr(k)}, v is {repr(v)}`);
}

print("\n");

try {
    for k.& in m { }
} catch err {
    dumpln(err);
}

print("\n");

let m = {"a": {"foo"}, "b": {"bar"}, "c": {"baz"}};
let i = 1;
dumpln(m);
for _, v.& in m {
    v.*.insert(i);
    i = i + 1;
}
dumpln(m);

print("\n");

let s = Set{"a", "b", "c"};
for x in s {
    println($`x is {repr(x)}`);
}

print("\n");

try {
    for x.& in s { }
} catch err {
    dumpln(err);
}

try {
    for k, v in s { }
} catch err {
    dumpln(err);
}

print("\n");

let fizzbuzzer = type {
    "init": function(n, max) {
        return new fizzbuzzer {"n": n, "max": max};
    },
    "next": function(self) {
        let n = self.*.n;
        if n > self.*.max {
            error null;
        }
        self.*.n = self.*.n + 1;
        if n % 3 == 0 and n % 5 == 0 {
            return "fizzbuzz";
        }
        if n % 3 == 0 {
            return "fizz";
        }
        if n % 5 == 0 {
            return "buzz";
        }
        return n;
    },
};
for x in fizzbuzzer::init(1, 15) {
    println(x);
}

print("\n");

try {
    for k.& in fizzbuzzer::init(1, 15) { }
} catch err {
    dumpln(err);
}

try {
    for k, v in fizzbuzzer::init(1, 15) { }
} catch err {
    dumpln(err);
}

print("\n");

# Validate the for loops close over a new environment with every execution of
# the loop body.

println("integer for-loop closures");
let fns = [];
for i in 3 {
    fns.push(function() { return i; });
}
for f in fns {
    println(f());
}

println("vector for-loop closures");
let fns = [];
for i in [0, 1, 2] {
    fns.push(function() { return i; });
}
for f in fns {
    println(f());
}

println("vector for-loop closures");
let fns = [];
for i in {0: null, 1: null, 2: null} {
    fns.push(function() { return i; });
}
for f in fns {
    println(f());
}

println("set for-loop closures");
let fns = [];
for i in {0, 1, 2} {
    fns.push(function() { return i; });
}
for f in fns {
    println(f());
}

println("iterator for-loop closures");
let T = type extends iterator {
    .init = function(end) {
        return new T {"i": 0, "end": end};
    },
    .next = function(self) {
        let i = self.i;
        if i >= self.end {
            error null;
        }
        self.i = self.i + 1;
        return i;
    },
};
let fns = [];
for i in T::init(3) {
    fns.push(function() { return i; });
}
for f in fns {
    println(f());
}

