let x = {"foo": {"bar": 123}};
let y = x;
println($`x is {x}`);
println($`y is {y}`);
y["foo"] = {"bar": 456};
println($`y["foo"] = {{"bar": 456}};`);
println($`x is now {x}`);
println($`y is now {y}`);

print("\n");

let x = {"foo": {"bar": 123}};
let y = x;
println($`x is {x}`);
println($`y is {y}`);
y["foo"]["bar"] = 456;
println($`y["foo"]["bar"] = 456;`);
println($`x is now {x}`);
println($`y is now {y}`);

print("\n");

let x = {"foo": {"bar": 123}};
let y = x;
println($`x is {x}`);
println($`y is {y}`);

println($`calling function with passing y as parameter z`);
function(z) {
    z["foo"] = {"bar": 456};
    println($`z["foo"] = {{"bar": 456}}; # inside function`);
    println($`x is {x} (inside function)`);
    println($`y is {y} (inside function)`);
    println($`z is {z} (inside function)`);
}(y);
println($`x is now {x} (outside function)`);
println($`y is now {y} (outside function)`);
################################################################################
# x is {"foo": {"bar": 123}}
# y is {"foo": {"bar": 123}}
# y["foo"] = {"bar": 456};
# x is now {"foo": {"bar": 123}}
# y is now {"foo": {"bar": 456}}
#
# x is {"foo": {"bar": 123}}
# y is {"foo": {"bar": 123}}
# y["foo"]["bar"] = 456;
# x is now {"foo": {"bar": 123}}
# y is now {"foo": {"bar": 456}}
#
# x is {"foo": {"bar": 123}}
# y is {"foo": {"bar": 123}}
# calling function with passing y as parameter z
# z["foo"] = {"bar": 456}; # inside function
# x is {"foo": {"bar": 123}} (inside function)
# y is {"foo": {"bar": 123}} (inside function)
# z is {"foo": {"bar": 456}} (inside function)
# x is now {"foo": {"bar": 123}} (outside function)
# y is now {"foo": {"bar": 123}} (outside function)
