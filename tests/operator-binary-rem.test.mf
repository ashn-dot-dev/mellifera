# "attempted % operation with types `function` and `function`"
#
# +7 % +3 is 1
# +7 % -3 is 1
# -7 % +3 is -1
# -7 % -3 is -1
# 10 % 3.5 is 3
# -Inf % +1 is NaN
# +Inf % -1 is NaN
# -Inf % -1 is NaN
# +1 % +Inf is 1
# +1 % -Inf is 1
# -1 % +Inf is -1
# -1 % -Inf is -1
# 0 % +Inf is 0
# 0 % -Inf is 0
# 1 / (0 % +Inf) is Inf
# 1 / (0 % -Inf) is Inf
# NaN % 1 is NaN
# 1 % Nan is NaN
# NaN % +Inf is NaN
# NaN % -Inf is NaN
# 1 % 0 is NaN
