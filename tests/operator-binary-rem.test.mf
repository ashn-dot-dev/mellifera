try { dumpln( null         % null          ); } catch err { dumpln(err); }
try { dumpln( true         % true          ); } catch err { dumpln(err); }
try { dumpln( 12           % 5             ); } catch err { dumpln(err); }
try { dumpln( "foo"        % "bar"         ); } catch err { dumpln(err); }
try { dumpln( []           % []            ); } catch err { dumpln(err); }
try { dumpln( Map{}        % Map{}         ); } catch err { dumpln(err); }
try { dumpln( Set{}        % Set{}         ); } catch err { dumpln(err); }
try { function(a, b){ a % b; }(123.&, 123.&); } catch err { dumpln(err); }
try { dumpln( function(){} % function(){}  ); } catch err { dumpln(err); }
try { dumpln( println      % println       ); } catch err { dumpln(err); }

print("\n");

# Verify remainder follows the behavior of C99.
println($`+7 % +3 is {+7 % +3}`);
println($`+7 % -3 is {+7 % -3}`);
println($`-7 % +3 is {-7 % +3}`);
println($`-7 % -3 is {-7 % -3}`);
println($`10 % 3.5 is {10 % 3.5}`);
println($`-Inf % +1 is {-Inf % +1}`);
println($`+Inf % -1 is {+Inf % -1}`);
println($`-Inf % -1 is {-Inf % -1}`);
println($`+1 % +Inf is {+1 % +Inf}`);
println($`+1 % -Inf is {+1 % -Inf}`);
println($`-1 % +Inf is {-1 % +Inf}`);
println($`-1 % -Inf is {-1 % -Inf}`);
println($`0 % +Inf is {0 % +Inf}`);
println($`0 % -Inf is {0 % -Inf}`);
println($`1 / (0 % +Inf) is {1 / (0 % +Inf)}`);
println($`1 / (0 % -Inf) is {1 / (0 % -Inf)}`);
println($`NaN % 1 is {NaN % 1}`);
println($`1 % Nan is {1 % NaN}`);
println($`NaN % +Inf is {NaN % +Inf}`);
println($`NaN % -Inf is {NaN % -Inf}`);
println($`1 % 0 is {1 % 0}`);
