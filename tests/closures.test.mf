let x = 123;
let y = {"foo": "bar"};
let f = function() {
    dumpln(x); # x is closed over
    dumpln(y.foo); # y is closed over
};

f();
print("\n");

let adder = function(x) {
    return function(y) {
        return x + y;
    };
};
let add1 = adder(1);
dumpln(add1(2));
################################################################################
# 123
# "bar"
#
# 3
