println($`math::copy_sign(+5, +0) is {math::copy_sign(+5, +0)}`);
println($`math::copy_sign(+5, -0) is {math::copy_sign(+5, -0)}`);
println($`math::copy_sign(-5, +0) is {math::copy_sign(-5, +0)}`);
println($`math::copy_sign(-5, -0) is {math::copy_sign(-5, -0)}`);
println($`math::copy_sign(+5, +2) is {math::copy_sign(+5, +2)}`);
println($`math::copy_sign(+5, -2) is {math::copy_sign(+5, -2)}`);
println($`math::copy_sign(-5, +2) is {math::copy_sign(-5, +2)}`);
println($`math::copy_sign(-5, -2) is {math::copy_sign(-5, -2)}`);
println($`math::copy_sign(+5, +Inf) is {math::copy_sign(+5, +Inf)}`);
println($`math::copy_sign(+5, -Inf) is {math::copy_sign(+5, -Inf)}`);
println($`math::copy_sign(-5, +Inf) is {math::copy_sign(-5, +Inf)}`);
println($`math::copy_sign(-5, -Inf) is {math::copy_sign(-5, -Inf)}`);
println($`math::copy_sign(+Inf, +2) is {math::copy_sign(+Inf, +2)}`);
println($`math::copy_sign(+Inf, -2) is {math::copy_sign(+Inf, -2)}`);
println($`math::copy_sign(-Inf, +2) is {math::copy_sign(+Inf, +2)}`);
println($`math::copy_sign(-Inf, -2) is {math::copy_sign(-Inf, -2)}`);
println($`math::copy_sign(+5, NaN) is {math::copy_sign(+5, NaN)}`);
println($`math::copy_sign(-5, NaN) is {math::copy_sign(-5, NaN)}`);
println($`math::copy_sign(NaN, +2) is {math::copy_sign(NaN, +2)}`);
println($`math::copy_sign(NaN, -2) is {math::copy_sign(NaN, -2)}`);
################################################################################
# math::copy_sign(+5, +0) is 5
# math::copy_sign(+5, -0) is -5
# math::copy_sign(-5, +0) is 5
# math::copy_sign(-5, -0) is -5
# math::copy_sign(+5, +2) is 5
# math::copy_sign(+5, -2) is -5
# math::copy_sign(-5, +2) is 5
# math::copy_sign(-5, -2) is -5
# math::copy_sign(+5, +Inf) is 5
# math::copy_sign(+5, -Inf) is -5
# math::copy_sign(-5, +Inf) is 5
# math::copy_sign(-5, -Inf) is -5
# math::copy_sign(+Inf, +2) is Inf
# math::copy_sign(+Inf, -2) is -Inf
# math::copy_sign(-Inf, +2) is Inf
# math::copy_sign(-Inf, -2) is -Inf
# math::copy_sign(+5, NaN) is 5
# math::copy_sign(-5, NaN) is 5
# math::copy_sign(NaN, +2) is NaN
# math::copy_sign(NaN, -2) is NaN
