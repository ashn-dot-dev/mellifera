println($`[123, 456, 789].slice(0, 0) is {[123, 456, 789].slice(0, 0)}`);
println($`[123, 456, 789].slice(0, 3) is {[123, 456, 789].slice(0, 3)}`);
println($`[123, 456, 789].slice(0, 1) is {[123, 456, 789].slice(0, 1)}`);
println($`[123, 456, 789].slice(1, 3) is {[123, 456, 789].slice(1, 3)}`);
try { [123, 456, 789].slice(0.5, 0); } catch err { println($`[123, 456, 789].slice(0.5, 0) produces the error {repr(err)}`); }
try { [123, 456, 789].slice(0, 1.5); } catch err { println($`[123, 456, 789].slice(0, 1.5) produces the error {repr(err)}`); }
try { [123, 456, 789].slice(-1, 0); } catch err { println($`[123, 456, 789].slice(-1, 0) produces the error {repr(err)}`); }
try { [123, 456, 789].slice(0, -1); } catch err { println($`[123, 456, 789].slice(0, -1) produces the error {repr(err)}`); }
try { [123, 456, 789].slice(math::pow(2, 100), 0); } catch err { println($`[123, 456, 789].slice(math::pow(2, 100), 0) produces the error {repr(err)}`); }
try { [123, 456, 789].slice(0, math::pow(2, 100)); } catch err { println($`[123, 456, 789].slice(0, math::pow(2, 100)) produces the error {repr(err)}`); }
try { [123, 456, 789].slice(3, 1); } catch err { println($`[123, 456, 789].slice(3, 1) produces the error {repr(err)}`); }
################################################################################
# [123, 456, 789].slice(0, 0) is []
# [123, 456, 789].slice(0, 3) is [123, 456, 789]
# [123, 456, 789].slice(0, 1) is [123]
# [123, 456, 789].slice(1, 3) is [456, 789]
# [123, 456, 789].slice(0.5, 0) produces the error "attempted vector::slice with invalid begin index 0.5 (cannot convert 0.5 into an integer without truncation)"
# [123, 456, 789].slice(0, 1.5) produces the error "attempted vector::slice with invalid end index 1.5 (cannot convert 1.5 into an integer without truncation)"
# [123, 456, 789].slice(-1, 0) produces the error "attempted vector::slice with invalid begin index -1 (integer -1 is outside the indexable integer range)"
# [123, 456, 789].slice(0, -1) produces the error "attempted vector::slice with invalid end index -1 (integer -1 is outside the indexable integer range)"
# [123, 456, 789].slice(math::pow(2, 100), 0) produces the error "attempted vector::slice with invalid begin index 1267650600228229401496703205376 (integer 1267650600228229401496703205376 is outside the indexable integer range)"
# [123, 456, 789].slice(0, math::pow(2, 100)) produces the error "attempted vector::slice with invalid end index 1267650600228229401496703205376 (integer 1267650600228229401496703205376 is outside the indexable integer range)"
# [123, 456, 789].slice(3, 1) produces the error "attempted vector::slice with invalid indices (slice end is less than slice begin)"
