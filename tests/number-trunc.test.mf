println($`(+123.45).trunc() is {(+123.45).trunc()}`);
println($`(-123.45).trunc() is {(-123.45).trunc()}`);
println($`Inf.trunc() is {Inf.trunc()}`);
println($`NaN.trunc() is {NaN.trunc()}`);
################################################################################
# (+123.45).trunc() is 123
# (-123.45).trunc() is -123
# Inf.trunc() is Inf
# NaN.trunc() is NaN
