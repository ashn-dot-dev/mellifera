println($`(+123.45).floor() is {(+123.45).floor()}`);
println($`(-123.45).floor() is {(-123.45).floor()}`);
println($`Inf.floor() is {Inf.floor()}`);
println($`NaN.floor() is {NaN.floor()}`);
################################################################################
# (+123.45).floor() is 123
# (-123.45).floor() is -124
# Inf.floor() is Inf
# NaN.floor() is NaN
