println($`(+123.45).ceil() is {repr((+123.45).ceil())}`);
println($`(-123.45).ceil() is {repr((-123.45).ceil())}`);
println($`Inf.ceil() is {Inf.ceil()}`);
println($`NaN.ceil() is {NaN.ceil()}`);
################################################################################
# (+123.45).ceil() is 124
# (-123.45).ceil() is -123
# Inf.ceil() is Inf
# NaN.ceil() is NaN
