# lvalue auto-deref (index notation)
let m = {"foo": "bar"};
let r = m.&;
r["foo"] = "baz";
dumpln(m);

# lvalue auto-deref (scope notation)
let m = {"foo": "bar"};
let r = m.&;
r::foo = "baz";
dumpln(m);

# lvalue auto-deref (dot notation)
let m = {"foo": "bar"};
let r = m.&;
r.foo = "baz";
dumpln(m);

# rvalue auto-deref (index notation)
let m = {"foo": "bar"};
let r = m.&;
dumpln(r.foo);

# rvalue auto-deref (scope notation)
let m = {"foo": "bar"};
let r = m.&;
dumpln(r::foo);

# rvalue auto-deref (dot notation)
let m = {"foo": "bar"};
let r = m.&;
dumpln(r["foo"]);
################################################################################
# {"foo": "baz"}
# {"foo": "baz"}
# {"foo": "baz"}
# "bar"
# "bar"
# "bar"
