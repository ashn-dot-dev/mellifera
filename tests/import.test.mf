# Import a module that does not exist.
try {
    import("nope.mf");
}
catch err {
    println(err);
}

# Import a module that does not exist using a valid directory that does exist.
try {
    import("../lib");
}
catch err {
    println(err);
}

# Import a module that does exist by the path to its main file.
try {
    let lib = import("../lib/zen/lib.mf");
}
catch err {
    println(err);
}

# Import a module that does exist by the path to its directory.
try {
    let lib = import("../lib/zen");
}
catch err {
    println(err);
}

# Ensure that the module field is properly restored after successful import.
try {
    assert(module::path.ends_with("import.test.mf"));
    assert(module::file == "import.test.mf");
    assert(module::directory.ends_with("/tests"));
    let lib = import("../lib/zen");
    assert(module::path.ends_with("import.test.mf"));
    assert(module::file == "import.test.mf");
    assert(module::directory.ends_with("/tests"));
}
catch err {
    println(err);
}

# Ensure that the module field is properly restored after a failed import.
try {
    assert(module::path.ends_with("import.test.mf"));
    assert(module::file == "import.test.mf");
    assert(module::directory.ends_with("/tests"));
    let lib = import("nope.mf");
    error "unreachable";
}
catch err {
    assert(module::path.ends_with("import.test.mf"));
    assert(module::file == "import.test.mf");
    assert(module::directory.ends_with("/tests"));
}
