# No reference closed over, so no error is produced.
let f = function(a) {
    for x in ["foo", "bar", "baz"] {
        for k, v in {"abc": 123, "def": 456} {
            return function() { };
        }
    }
};
f(null);

# Multiple references closed over, so an error is produced containing
# information on each closed-over reference.
let f = function(a) {
    for x.& in ["foo", "bar", "baz"] {
        for k, v.& in {"abc": 123, "def": 456} {
            return function() { };
        }
    }
};
f(null.&);
