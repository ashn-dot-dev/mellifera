try { dumpln( null         + null         ); } catch err { dumpln(err); }
try { dumpln( true         + true         ); } catch err { dumpln(err); }
try { dumpln( 123          + 456          ); } catch err { dumpln(err); }
try { dumpln( "foo"        + "bar"        ); } catch err { dumpln(err); }
try { dumpln( ["foo"]      + ["bar"]      ); } catch err { dumpln(err); }
try { dumpln( Map{}        + Map{}        ); } catch err { dumpln(err); }
try { dumpln( Set{}        + Set{}        ); } catch err { dumpln(err); }
try { dumpln( 123.&        + 123.&        ); } catch err { dumpln(err); }
try { dumpln( function(){} + function(){} ); } catch err { dumpln(err); }
try { dumpln( println      + println      ); } catch err { dumpln(err); }

print("\n");

# Adding two vectors should create a new vector with deep-copied elements.
let a = [[123, 456, 789]];
let b = [["abc", "def", "hij"]];
println($`a is {a}`);
println($`b is {b}`);
let c = a + b;
println($`c is {c}`);

a.push("foo");
println($`after a.push("foo") a is {a}`);
a[0].push("bar");
println($`after a[0].push("bar") a is {a}`);
b.push("qux");
println($`after b.push("qux") b is {b}`);
b[0].push("quz");
println($`after b[0].push("quz") b is {b}`);
println($`after these updates c is {c}`);

print("\n");

# Adding two vectors should create a new vector with deep-copied elements.
let a = [[123, 456, 789]];
let b = [["abc", "def", "hij"]];
println($`a is {a}`);
println($`b is {b}`);
let c = a + b;
println($`c is {c}`);

c[0].push("foo");
println($`after c[0].push("foo") a is {a}`);
println($`after c[0].push("foo") b is {b}`);
println($`after c[0].push("foo") c is {c}`);
c[1].push("bar");
println($`after c[1].push("bar") a is {a}`);
println($`after c[1].push("bar") b is {b}`);
println($`after c[1].push("bar") c is {c}`);
