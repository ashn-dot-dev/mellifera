println($`(+123.45).round() is {(+123.45).round()}`);
println($`(-123.45).round() is {(-123.45).round()}`);
println($`(+123.54).round() is {(+123.54).round()}`);
println($`(-123.54).round() is {(-123.54).round()}`);
println($`Inf.round() is {Inf.round()}`);
println($`NaN.round() is {NaN.round()}`);
################################################################################
# (+123.45).round() is 123
# (-123.45).round() is -123
# (+123.54).round() is 124
# (-123.54).round() is -124
# Inf.round() is Inf
# NaN.round() is NaN
