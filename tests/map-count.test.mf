println($`Map{{}}.count() is {Map{}.count()}`);
println($`Map{{"foo": 123, "bar": 456, "baz": 789}}.count() is {Map{"foo": 123, "bar": 456, "baz": 789}.count()}`);
################################################################################
# Map{}.count() is 0
# Map{"foo": 123, "bar": 456, "baz": 789}.count() is 3
