dumpln(math::clamp(100, 100, 200));
dumpln(math::clamp(150, 100, 200));
dumpln(math::clamp(200, 100, 200));
dumpln(math::clamp(0, 100, 200));
dumpln(math::clamp(300, 100, 200));
dumpln(math::clamp(100, 150, 150));
dumpln(math::clamp(150, 150, 150));
dumpln(math::clamp(NaN, 100, 200));
try { dumpln(math::clamp(150, 1, 0)); } catch err { dumpln(err); }
try { dumpln(math::clamp(150, NaN, 1)); } catch err { dumpln(err); }
try { dumpln(math::clamp(150, 0, NaN)); } catch err { dumpln(err); }
