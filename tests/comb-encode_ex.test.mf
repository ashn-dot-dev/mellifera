let value = {
    "foo": null,
    "bar": 123,
    "baz": "hello",
    "qux": [
        "abc",
        "def",
        "hij",
    ],
    "quy": {
        "abc": 123,
        "def": 456,
    },
    "quz": {
        "abc",
        "def",
        "hij",
    },
};

# Encode with integer indent.
println(comb::encode_ex(value, {"indent": 2, "separator": " "}));
println(comb::encode_ex(value, {"indent": 4, "separator": " "}));

print("\n");

# Encode with string indent.
println(comb::encode_ex(value, {"indent": "  ", "separator": " "}));
println(comb::encode_ex(value, {"indent": "<indent>", "separator": "<separator>"}));

print("\n");

# Encode with empty collections.
println(comb::encode_ex({"foo": [], "bar": Map{}, "baz": Set{}}, {"indent": 4, "separator": " "}));

print("\n");

# Encode with no indent or separator options.
println(comb::encode_ex([123, 456], Map{}));
println(comb::encode_ex({"abc": 123, "def": 456}, Map{}));
println(comb::encode_ex({123, 456}, Map{}));

print("\n");

# Encode with non-positive-integer indent.
try { println(comb::encode_ex(value, {"indent": -1})); } catch err { dumpln(err); }
# Encode with non-integer indent.
try { println(comb::encode_ex(value, {"indent": 0.5})); } catch err { dumpln(err); }
# Encode with non-number non-string indent.
try { println(comb::encode_ex(value, {"indent": null})); } catch err { dumpln(err); }
# Encode with non-string separator.
try { println(comb::encode_ex(value, {"separator": null})); } catch err { dumpln(err); }
