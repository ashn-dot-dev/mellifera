random::seed("foo");
let min = 0;
let max = 0;
for i in 10000 {
    let x = random::integer(-10, +10);
    assert(x.is_integer());
    assert(x >= -10);
    assert(x <= +10);
    if x < min { min = x; }
    if x > max { max = x; }
}

try {
    random::integer(+1, -1);
}
catch err {
    dumpln(err);
}

try {
    random::integer(-1.5, +1);
}
catch err {
    dumpln(err);
}

try {
    random::integer(-1, +1.5);
}
catch err {
    dumpln(err);
}

try {
    random::integer(-math::pow(2, 100), +1);
}
catch err {
    dumpln(err);
}


try {
    random::integer(-1, +math::pow(2, 100));
}
catch err {
    dumpln(err);
}
################################################################################
# "min > max (1 > -1)"
# "expected integer lower bound, received -1.5"
# "expected integer upper bound, received 1.5"
# "integer -1267650600228229401496703205376 is outside the safe integer range"
# "integer 1267650600228229401496703205376 is outside the safe integer range"
