let x = {"foo", "bar"};
let y = x;
println($`x is {x}`);
println($`y is {y}`);
y.insert("baz");
println($`y.insert("baz");`);
println($`x is now {x}`);
println($`y is now {y}`);

print("\n");

let x = {"foo", "bar"};
let y = x;
println($`x is {x}`);
println($`y is {y}`);
y.remove("foo");
println($`y.remove("foo");`);
println($`x is now {x}`);
println($`y is now {y}`);

print("\n");

let x = {"foo", "bar"};
let y = x;
println($`x is {x}`);
println($`y is {y}`);

println($`calling function with passing y as parameter z`);
function(z) {
    z.insert("baz");
    println($`z.insert("baz"); # inside function`);
    println($`x is {x} (inside function)`);
    println($`y is {y} (inside function)`);
    println($`z is {z} (inside function)`);
}(y);
println($`x is now {x} (outside function)`);
println($`y is now {y} (outside function)`);
################################################################################
# x is {"foo", "bar"}
# y is {"foo", "bar"}
# y.insert("baz");
# x is now {"foo", "bar"}
# y is now {"foo", "bar", "baz"}
#
# x is {"foo", "bar"}
# y is {"foo", "bar"}
# y.remove("foo");
# x is now {"foo", "bar"}
# y is now {"bar"}
#
# x is {"foo", "bar"}
# y is {"foo", "bar"}
# calling function with passing y as parameter z
# z.insert("baz"); # inside function
# x is {"foo", "bar"} (inside function)
# y is {"foo", "bar"} (inside function)
# z is {"foo", "bar", "baz"} (inside function)
# x is now {"foo", "bar"} (outside function)
# y is now {"foo", "bar"} (outside function)
