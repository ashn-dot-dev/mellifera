try { dumpln( null["foo"]                        ); } catch err { dumpln(err); }
try { dumpln( null[0]                            ); } catch err { dumpln(err); }
try { dumpln( true["foo"]                        ); } catch err { dumpln(err); }
try { dumpln( true[0]                            ); } catch err { dumpln(err); }
try { dumpln( 123["foo"]                         ); } catch err { dumpln(err); }
try { dumpln( 123[0]                             ); } catch err { dumpln(err); }
try { dumpln( "foo"["foo"]                       ); } catch err { dumpln(err); }
try { dumpln( "foo"[0]                           ); } catch err { dumpln(err); }
try { dumpln( ["foo", "bar"]["foo"]              ); } catch err { dumpln(err); }
try { dumpln( ["foo", "bar"][0]                  ); } catch err { dumpln(err); }
try { dumpln( Map{"foo": 123, "bar": 456}["foo"] ); } catch err { dumpln(err); }
try { dumpln( Map{"foo": 123, "bar": 456}[0]     ); } catch err { dumpln(err); }
try { dumpln( Set{"foo", "bar"}["foo"]           ); } catch err { dumpln(err); }
try { dumpln( Set{"foo", "bar"}[0]               ); } catch err { dumpln(err); }
try { function(ref){ ref["foo"]; }(123.&);          } catch err { dumpln(err); }
try { function(ref){ ref[0]; }(123.&);              } catch err { dumpln(err); }
try { dumpln( function(){}["foo"]                ); } catch err { dumpln(err); }
try { dumpln( function(){}[0]                    ); } catch err { dumpln(err); }
try { dumpln( println["foo"]                     ); } catch err { dumpln(err); }
try { dumpln( println[0]                         ); } catch err { dumpln(err); }

print("\n");

let x = ["foo", "bar", "baz"];
dumpln(x);
x[1] = "xyz";
dumpln(x);
try { dumpln(x[3]); } catch err { dumpln(err); }
try { dumpln(x[-1]); } catch err { dumpln(err); }
try { dumpln(x["foo"]); } catch err { dumpln(err); }
try { x[3] = "xyz"; } catch err { dumpln(err); }
try { x[-1] = "xyz"; } catch err { dumpln(err); }
try { x["foo"] = "xyz"; } catch err { dumpln(err); }

print("\n");

let x = {"foo": 123, "bar": 456};
dumpln(x);
x["foo"] = "xyz";
dumpln(x);
try { dumpln(x["baz"]); } catch err { dumpln(err); }
