dumpln(comb::decode(`null`));

print("\n");

dumpln(comb::decode(`true`));
dumpln(comb::decode(`false`));

print("\n");

dumpln(comb::decode(`123`));
dumpln(comb::decode(`123.456`));
dumpln(comb::decode(`+123.456`));
dumpln(comb::decode(`-123.456`));
try { dumpln(comb::decode(`NaN`)); } catch err { println($"error: {err}"); }
try { dumpln(comb::decode(`Inf`)); } catch err { println($"error: {err}"); }

print("\n");

dumpln(comb::decode(`"foo"`));
dumpln(comb::decode(`"foo\nbar"`));
dumpln(comb::decode("`foo\\nbar`"));

print("\n");

dumpln(comb::decode(`[]`));
dumpln(comb::decode(`["foo", "bar", "baz"]`));
dumpln(comb::decode(`["foo", ["bar"], {"baz": 123}]`));

print("\n");

dumpln(comb::decode(`Map{}`));
dumpln(comb::decode(`{"foo": 123}`));
dumpln(comb::decode(`{"foo": 123, "bar": ["abc", "def"], "baz": {"blub": null}}`));
dumpln(comb::decode(`{.foo = 123, .bar = ["abc", "def"], .baz = {"blub": null}}`));

# Test non-string keys.
dumpln(comb::decode(`{null: null}`));
dumpln(comb::decode(`{true: null}`));
dumpln(comb::decode(`{123: null}`));
dumpln(comb::decode(`{[123, 456]: null}`));
dumpln(comb::decode(`{Map{123: 456}: null}`));
dumpln(comb::decode(`{Set{123, 456}: null}`));

print("\n");

dumpln(comb::decode(`Set{}`));
dumpln(comb::decode(`{"foo", "bar"}`));
dumpln(comb::decode(`{"foo", ["abc", "def"], {"blub": null}}`));

print("\n");

try { comb::decode(""); } catch err { println($"error: {err}"); }
try { comb::decode(" "); } catch err { println($"error: {err}"); }
try { comb::decode("  "); } catch err { println($"error: {err}"); }
try { comb::decode("   "); } catch err { println($"error: {err}"); }
try { comb::decode("bad"); } catch err { println($"error: {err}"); }
try { comb::decode("N"); } catch err { println($"error: {err}"); } # first character of NaN
try { comb::decode("Na"); } catch err { println($"error: {err}"); } # first two characters of NaN
try { comb::decode("I"); } catch err { println($"error: {err}"); } # first character of Inf
try { comb::decode("In"); } catch err { println($"error: {err}"); } # first two characters of Inf
try { comb::decode(`{}`); } catch err { println($"error: {err}"); } # ambigious set or map
try { comb::decode("Map{}123"); } catch err { println($"error: {err}"); } # extra characters after valid JSON
try { comb::decode("Map{}r`foo`"); } catch err { println($"error: {err}"); } # extra characters after valid JSON
try { comb::decode("Map{}extra"); } catch err { println($"error: {err}"); } # extra characters after valid JSON
################################################################################
# null
#
# true
# false
#
# 123
# 123.456
# 123.456
# -123.456
# error: expected expression, found NaN
# error: expected expression, found Inf
#
# "foo"
# "foo\nbar"
# "foo\\nbar"
#
# []
# ["foo", "bar", "baz"]
# ["foo", ["bar"], {"baz": 123}]
#
# Map{}
# {"foo": 123}
# {"foo": 123, "bar": ["abc", "def"], "baz": {"blub": null}}
# {"foo": 123, "bar": ["abc", "def"], "baz": {"blub": null}}
# {null: null}
# {true: null}
# {123: null}
# {[123, 456]: null}
# {{123: 456}: null}
# {{123, 456}: null}
#
# Set{}
# {"foo", "bar"}
# {"foo", ["abc", "def"], {"blub": null}}
#
# error: expected expression, found end-of-file
# error: expected expression, found end-of-file
# error: expected expression, found end-of-file
# error: expected expression, found end-of-file
# error: expected expression, found bad
# error: expected expression, found N
# error: expected expression, found Na
# error: expected expression, found I
# error: expected expression, found In
# error: ambiguous empty map or set
# error: expected end-of-file, found 123
# error: expected end-of-file, found r`foo`
# error: expected end-of-file, found extra
