# a reference into x only aliases x, not y
let x = [{"abc": "foo"}];
let y = x;
function(r) { r["abc"] = "bar"; }(x[0].&);
dumpln(x);
dumpln(y);

print("\n");

# a reference into y only aliases y, not x
let x = [{"abc": "foo"}];
let y = x;
function(r) { r["abc"] = "bar"; }(y[0].&);
dumpln(x);
dumpln(y);

print("\n");

# a reference into x only aliases x, not y
let x = {"a": {"abc": "foo"}};
let y = x;
function(r) { r["abc"] = "bar"; }(x["a"].&);
dumpln(x);
dumpln(y);

print("\n");

# a reference into y only aliases y, not x
let x = {"a": {"abc": "foo"}};
let y = x;
function(r) { r["abc"] = "bar"; }(y["a"].&);
dumpln(x);
dumpln(y);

print("\n");

# a reference taken before multiple copies should not alias any of those copies
let x = [{"abc": "foo"}];
let y = x;
let z = x;
function(r) { r["abc"] = "bar"; }(x[0].&);
dumpln(x);
dumpln(y);
dumpln(z);

print("\n");

# deeply nested references should only reference their original value
let x = {"a": {"b": {"abc": "foo"}}};
let y = x;
function(r) { r["abc"] = "bar"; }(x["a"]["b"].&);
dumpln(x);
dumpln(y);

print("\n");

# member function call implicitly creating a shared reference (top-level)
let x = ["foo", "bar"];
let y = x;
x.push("baz");
dumpln(x);
dumpln(y);

print("\n");

# member function call implicitly creating a shared reference (one level of nesting)
let x = {"a": ["foo", "bar"]};
let y = x;
x.a.push("baz");
dumpln(x);
dumpln(y);

print("\n");

# member function call implicitly creating a shared reference (two levels of nesting)
let x = {"a": {"b": ["foo", "bar"]}};
let y = x;
x.a.b.push("baz");
dumpln(x);
dumpln(y);

print("\n");

# for-loop over reference to shared vector elements
let x = [{"n": 123}, {"n": 456}];
let y = x;
for v.& in x {
  v["n"] = v["n"] + 1;
}
dumpln(x);
dumpln(y);

print("\n");

# for-loop over reference to shared map values
let x = {"a": {"n": 123}, "b": {"n": 456}};
let y = x;
for k, v.& in x {
  v["n"] = v["n"] + 1;
}
dumpln(x);
dumpln(y);

print("\n");

# snapshots of a vector before modification through referenced elements
let v = [{"abc": "foo"}];
let snapshot = null;
for x.& in v {
    snapshot = v;
    x["abc"] = "bar";
}
dumpln(v);
dumpln(snapshot);

print("\n");

# snapshots of a map before modification through referenced values
let m = {"a": {"n": 123}};
let snapshot = null;
for k, x.& in m {
    snapshot = m;
    x["n"] = x["n"] + 1;
}
dumpln(m);
dumpln(snapshot);

print("\n");

# modifying a vector during iteration should not affect the iterated elements
let v = [{"n": 123}];
for x.& in v {
    x["n"] = x["n"] + 1;
    v.push({"n": "bar"});
}
dumpln(v);

print("\n");

# modifying a map during iteration should not affect the iterated elements
let m = {"a": {"n": 123}, "b": {"n": 456}};
for k, x.& in m {
    x["n"] = x["n"] + 1;
    m.insert("c", {"n": "bar"});
}
dumpln(m);
