# {"a": {"abc": "bar"}}
#
# [{"abc": "bar"}]
# [{"abc": "foo"}]
# [{"abc": "foo"}]
#
# {"a": {"b": {"abc": "bar"}}}
# {"a": {"b": {"abc": "foo"}}}
#
# ["foo", "bar", "baz"]
# ["foo", "bar"]
#
# {"a": ["foo", "bar", "baz"]}
# {"a": ["foo", "bar"]}
#
# {"a": {"b": ["foo", "bar", "baz"]}}
# {"a": {"b": ["foo", "bar"]}}
#
# [{"n": 124}, {"n": 457}]
# [{"n": 123}, {"n": 456}]
#
# {"a": {"n": 124}, "b": {"n": 457}}
# {"a": {"n": 123}, "b": {"n": 456}}
#
# [{"abc": "bar"}]
# [{"abc": "foo"}]
#
# {"a": {"n": 124}}
# {"a": {"n": 123}}
#
# [{"n": 124}, {"n": "bar"}]
#
# {"a": {"n": 124}, "b": {"n": 457}, "c": {"n": "bar"}}
