# x and y are separate values, so x[0].& should only reference into x
let x = [{"abc": "foo"}];
let r = x[0].&; # assign reference r before copying vector x
let y = x;
r["abc"] = "bar";
dumpln(x);
dumpln(y);

print("\n");

# x and y are separate values, so x[0].& should only reference into x
let x = [{"abc": "foo"}];
let y = x;
let r = x[0].&; # assign reference r after copying vector x
r["abc"] = "bar";
dumpln(x);
dumpln(y);

print("\n");

# x and y are separate values, so y[0].& should only reference into y
let x = [{"abc": "foo"}];
let y = x;
let r = y[0].&; # assign reference r after copying vector y
r["abc"] = "bar";
dumpln(x);
dumpln(y);

print("\n");

# x and y are separate values, so x["a"].& should only reference into x
let x = {"a": {"abc": "foo"}};
let r = x["a"].&; # assign reference r before copying map x
let y = x;
r["abc"] = "bar";
dumpln(x);
dumpln(y);

print("\n");

# x and y are separate values, so x["a"].& should only reference into x
let x = {"a": {"abc": "foo"}};
let y = x;
let r = x["a"].&; # assign reference r after copying map x
r["abc"] = "bar";
dumpln(x);
dumpln(y);

print("\n");

# x and y are separate values, so y["a"].& should only reference into y
let x = {"a": {"abc": "foo"}};
let y = x;
let r = y["a"].&; # assign reference r after copying map x
r["abc"] = "bar";
dumpln(x);
dumpln(y);

print("\n");

# copy-on-write applied to a value with multiple references should be visible
# to both references.
let x = {"abc": "foo"};
let y = x;
let r1 = x.&;
let r2 = x.&;
r1["abc"] = "bar";
dumpln(x);
dumpln(y);
dumpln(r1.*);
dumpln(r2.*);

print("\n");

# a reference taken before multiple copies should not alias any of those copies
let x = [{"abc": "foo"}];
let r = x[0].&;
let y = x;
let z = x;
r["abc"] = "bar";
dumpln(x);
dumpln(y);
dumpln(z);

print("\n");

# deeply nested references should only reference their original value
let x = {"a": {"b": {"abc": "foo"}}};
let y = x;
let r = x["a"]["b"].&;
r["abc"] = "bar";
dumpln(x);
dumpln(y);

print("\n");

# member function call implicitly creating a shared reference (top-level)
let x = ["foo", "bar"];
let y = x;
x.push("baz");
dumpln(x);
dumpln(y);

print("\n");

# member function call implicitly creating a shared reference (one level of nesting)
let x = {"a": ["foo", "bar"]};
let y = x;
x.a.push("baz");
dumpln(x);
dumpln(y);

print("\n");

# member function call implicitly creating a shared reference (two levels of nesting)
let x = {"a": {"b": ["foo", "bar"]}};
let y = x;
x.a.b.push("baz");
dumpln(x);
dumpln(y);

print("\n");

# for-loop over reference to shared vector elements
let x = [{"n": 123}, {"n": 456}];
let y = x;
for v.& in x {
  v["n"] = v["n"] + 1;
}
dumpln(x);
dumpln(y);

print("\n");

# for-loop over reference to shared map values
let x = {"a": {"n": 123}, "b": {"n": 456}};
let y = x;
for k, v.& in x {
  v["n"] = v["n"] + 1;
}
dumpln(x);
dumpln(y);

print("\n");

# snapshots of a vector before modification through referenced elements
let v = [{"abc": "foo"}];
let snapshot = null;
for x.& in v {
    snapshot = v;
    x["abc"] = "bar";
}
dumpln(v);
dumpln(snapshot);

print("\n");

# snapshots of a map before modification through referenced values
let m = {"a": {"n": 123}};
let snapshot = null;
for k, x.& in m {
    snapshot = m;
    x["n"] = x["n"] + 1;
}
dumpln(m);
dumpln(snapshot);

print("\n");

# modifying a vector during iteration should not affect the iterated elements
let v = [{"n": 123}];
let snapshot = null;
for x.& in v {
    x["n"] = x["n"] + 1;
    v.push({"n": "bar"});
}
dumpln(v);

print("\n");

# modifying a map during iteration should not affect the iterated elements
let m = {"a": {"n": 123}, "b": {"n": 456}};
for k, x.& in m {
    x["n"] = x["n"] + 1;
    m.insert("c", {"n": "bar"});
}
dumpln(m);

print("\n");

# reference escaping from a function
let T = type {
    .ref = function(self) {
        return self;
    },
};
let x = {"data": new T {"abc": "foo"}};
let r = x["data"].ref(); # r references x["data"]
let y = x;
r["abc"] = "bar";
dumpln(x);
dumpln(y);

print("\n");

# reference captured by an enclosing function
let T = type {
    .fn = function(self) {
        return function() {
            self["abc"] = "bar";
        };
    },
};
let x = {"data": new T {"abc": "foo"}};
let f = x["data"].fn(); # f closes over a reference to x["data"]
let y = x;
f();
dumpln(x);
dumpln(y);
